APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# CORS / frontend (GitHub Pages + Vite local)
FRONTEND_URL=https://ronald-f18.github.io
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,ronald-f18.github.io

APP_TIMEZONE=America/Bogota

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=usuarios
DB_USERNAME=root
DB_PASSWORD=

MYSQL_ATTR_SSL_CA=/var/www/html/ca.pem

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Sistema RRHH"

JWT_SECRET=

# Asistente RRHH (chat): diccionario en BD; OpenAI opcional
CHATBOT_OPENAI_ENABLED=false
OPENAI_API_KEY=
CHATBOT_OPENAI_MODEL=gpt-4o-mini
CHATBOT_OPENAI_TIMEOUT=45
CHATBOT_MAX_CONTEXT_MESSAGES=12
# Máximo de chips de seguimiento en POST mensajes (3–6; por defecto 4)
# CHATBOT_SUGERENCIAS_RELACIONADAS_MAX=4
# Opcional: sustituye el system prompt por defecto del asistente (OpenAI)
# CHATBOT_SYSTEM_PROMPT_BASE="..."